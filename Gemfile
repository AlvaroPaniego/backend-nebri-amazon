source "https://rubygems.org"

ruby "~> 3.2"

# Core Rails framework (API mode)
gem "rails", "~> 7.1.0"

# PostgreSQL adapter
gem "pg", "~> 1.5"

# Authentication and security
gem "bcrypt", "~> 3.1"
gem "jwt", "~> 2.5"

# CORS handling
gem "rack-cors"

# Testing framework
group :development, :test do
  gem "rspec-rails", "~> 6.0"
  gem "factory_bot_rails", "~> 6.4"
  gem "database_cleaner-active_record", "~> 2.0"
end
gem 'puma'
